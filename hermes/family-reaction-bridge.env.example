# Copy outside the repository as /etc/family-reaction-bridge.env
# and set mode 0600.  Values below are placeholders only.

# Bind only to a private/Tailscale address that Home Assistant can reach.
FAMILY_REACTION_BRIDGE_BIND=100.0.0.0
FAMILY_REACTION_BRIDGE_PORT=38181
FAMILY_REACTION_BRIDGE_ALLOWED_PEERS=192.0.2.10
# This same dedicated bridge token also authenticates signed callbacks to HA;
# it is never sent in the callback body or URL.
FAMILY_REACTION_BRIDGE_TOKEN=replace-with-a-random-32-plus-character-token

# The router owns the family destination; callers cannot choose it.
FAMILY_REACTION_BRIDGE_FAMILY_CHAT_ID=replace-with-family-chat-id
FAMILY_REACTION_BRIDGE_SEND_URL=http://127.0.0.1:3000/send

# HA supplies only an unguessable webhook below this origin.  No HA long-lived
# token is stored on Hermes.
FAMILY_REACTION_BRIDGE_CALLBACK_ORIGIN=https://home-assistant.example.com

FAMILY_REACTION_BRIDGE_SOURCE_LOG=/var/lib/family-reaction-bridge/whatsapp-reactions.jsonl
FAMILY_REACTION_BRIDGE_DB=/var/lib/family-reaction-bridge/family-reaction-bridge.sqlite3
FAMILY_REACTION_BRIDGE_POLL_SECONDS=2

# Optional migration fan-out for existing family-alert consumers. Each listed
# JSONL is isolated; existing consumers validate their own target IDs.
FAMILY_REACTION_BRIDGE_LEGACY_INBOXES=/var/lib/family-reaction-bridge/family-alerts.jsonl
